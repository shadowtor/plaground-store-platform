{
  "name": "connector",
  "version": "0.0.1",
  "private": true,
  "description": "PLAground local connector — bridges cloud commands to BambuLab printers via LAN",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/connector.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.2",
    "ws": "^8.18.2",
    "pino": "^9.6.0",
    "packages/contracts": "workspace:*",
    "packages/config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.0"
  }
}
