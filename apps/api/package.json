{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "description": "PLAground Fastify API — domain logic, auth, RBAC, OpenAPI",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.3.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/csrf-protection": "^7.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.5.0",
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.50.0",
    "zod": "^3.24.2",
    "argon2": "^0.44.0",
    "@otplib/preset-default": "^12.0.1",
    "stripe": "^17.7.0",
    "ioredis": "^5.6.0",
    "nodemailer": "^7.0.3",
    "@aws-sdk/client-s3": "^3.790.0",
    "@aws-sdk/s3-request-presigner": "^3.790.0",
    "uuid": "^11.1.0",
    "pino": "^9.6.0",
    "config": "^1.0.0",
    "packages/config": "workspace:*",
    "packages/contracts": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.8.3",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0"
  }
}
