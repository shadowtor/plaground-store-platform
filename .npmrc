# pnpm node-linker: hoisted avoids symlinks in node_modules, required for UNC/network-share paths on Windows.
# store-dir: move pnpm store to local drive so pnpm project-registry symlinks work.
# (Symlinks to/from \\NAS UNC paths require elevated privileges on Windows.)
node-linker=hoisted
store-dir=C:/Users/shado/.pnpm-store
